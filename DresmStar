def get_long_memory(key):
    conn = sqlite3.connect(DB_PATH)
    row = conn.execute("SELECT value FROM memories WHERE key=?", (key,)).fetchone()
    conn.close()
    return row[0] if row else None

def set_long_memory(key, value):
    conn = sqlite3.connect(DB_PATH)
    conn.execute("INSERT OR REPLACE INTO memories (key, value, updated_at) VALUES (?, ?, CURRENT_TIMESTAMP)", (key, value))
    conn.commit()
    conn.close()

def clear_all_long_memory():
    conn = sqlite3.connect(DB_PATH)
    conn.execute("DELETE FROM memories")
    conn.commit()
    conn.close()

# ---------- 短期记忆 ----------
def load_memory():
    if not os.path.exists(MEMORY_FILE): return []
    with open(MEMORY_FILE, 'r', encoding='utf-8') as f:
        return [line.strip() for line in f if line.strip()]
def save_memory(lines):
    with open(MEMORY_FILE, 'w', encoding='utf-8') as f:
        f.write("\n".join(lines))
def add_memory_item(item):
    lines = load_memory()
    lines.append(item)
    save_memory(lines)
def delete_memory_item(idx):
    lines = load_memory()
    if 0 <= idx < len(lines):
        del lines[idx]
        save_memory(lines)
def update_memory_item(idx, new_text):
    lines = load_memory()
    if 0 <= idx < len(lines):
        lines[idx] = new_text
        save_memory(lines)
def clear_all_memory():
    save_memory([])

# ---------- 工具实现（命令执行、数据处理、OCR、TTS、技能等）----------
def _execute_command_safe(cmd):
    try:
        res = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=20)
        out = res.stdout + res.stderr
        return out[:2000] if out.strip() else "✅ 命令已执行"
    except Exception as e:
        return f"❌ 执行失败: {str(e)}"

def run_command(cmd):
    level = check_command_danger_level(cmd)
    if level == 2:
        return "⚠️ 严重危险命令已自动拦截（可能破坏系统）"
    if level == 1:
        global _pending_warning_command
        _pending_warning_command = {"command": cmd, "pending_since": time.time()}
        return (f"⚠️ 此操作可能影响系统稳定性或数据安全\n\n命令：`{cmd}`\n\n"
                "**免责声明**：继续执行后果自负。\n请回复「同意执行」或「拒绝」")
    return _execute_command_safe(cmd)

# ---------- 全新网络搜索模块（文本/新闻/图片/抓取）----------
def search_web(query: str, max_results: int = 5) -> str:
    """文本搜索（DuckDuckGo）"""
    if ddgs is None:
        return "搜索功能不可用：请安装 duckduckgo-search"
    try:
        from duckduckgo_search import DDGS
        with DDGS() as ddgs_obj:
            results = list(ddgs_obj.text(query, max_results=max_results))
        if not results:
            return f"未找到关于“{query}”的搜索结果"
        formatted = []
        for r in results:
            title = r.get('title', '无标题')
            href = r.get('href', '#')
            body = r.get('body', '无摘要')
            formatted.append(f"- **{title}**\n  链接：{href}\n  摘要：{body}\n")
        return f"🔍 关于“{query}”的搜索结果：\n\n" + "\n".join(formatted)
    except Exception as e:
        logger.error(f"搜索失败: {e}")
        return f"搜索出错：{e}"

def search_news(query: str, max_results: int = 5) -> str:
    """新闻搜索"""
    if ddgs is None:
        return "新闻搜索不可用：请安装 duckduckgo-search"
    try:
        from duckduckgo_search import DDGS
        with DDGS() as ddgs_obj:
            results = list(ddgs_obj.news(query, max_results=max_results))
        if not results:
            return f"未找到关于“{query}”的新闻"
        formatted = []
        for r in results:
            title = r.get('title', '无标题')
            href = r.get('url', '#')
            date = r.get('date', '未知日期')
            body = r.get('body', '无摘要')
            formatted.append(f"- **{title}** ({date})\n  链接：{href}\n  摘要：{body}\n")
        return f"📰 关于“{query}”的新闻：\n\n" + "\n".join(formatted)
    except Exception as e:
        logger.error(f"新闻搜索失败: {e}")
        return f"新闻搜索出错：{e}"

def search_images(query: str, max_results: int = 5) -> str:
    """图片搜索（返回图片链接）"""
    if ddgs is None:
        return "图片搜索不可用：请安装 duckduckgo-search"
    try:
        from duckduckgo_search import DDGS
        with DDGS() as ddgs_obj:
            results = list(ddgs_obj.images(query, max_results=max_results))
        if not results:
            return f"未找到关于“{query}”的图片"
        formatted = []
        for r in results:
            title = r.get('title', '无标题')
            img_url = r.get('image', '#')
            source = r.get('source', '未知来源')
            formatted.append(f"- **{title}**\n  图片链接：{img_url}\n  来源：{source}\n")
        return f"🖼️ 关于“{query}”的图片结果：\n\n" + "\n".join(formatted)
    except Exception as e:
        logger.error(f"图片搜索失败: {e}")
        return f"图片搜索出错：{e}"

def fetch_webpage(url: str) -> str:
    """抓取指定网页的核心正文内容"""
    if requests_lib is None or bs4 is None:
        return "网页抓取不可用：请安装 requests 和 beautifulsoup4"
    if not url.startswith(('http://', 'https://')):
        url = 'https://' + url
    try:
        # 静态抓取
        headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}
        resp = requests_lib.get(url, timeout=15, headers=headers)
        resp.raise_for_status()
        # 尝试使用 readability 提取正文
        if readability:
            from readability import Document
            doc = Document(resp.text)
            content = doc.summary()
            # 用 BeautifulSoup 提取纯文本
            soup = bs4.BeautifulSoup(content, 'html.parser')
            text = soup.get_text(separator='\n', strip=True)
        else:
            # 普通提取：移除脚本和样式
            soup = bs4.BeautifulSoup(resp.text, 'html.parser')
            for script in soup(["script", "style"]):
                script.decompose()
            text = soup.get_text(separator='\n', strip=True)
        # 限制长度
        if len(text) > 3000:
            text = text[:3000] + "...\n[内容过长，已截断]"
        return f"📄 网页内容摘要（{url}）：\n\n{text}"
    except Exception as e:
        logger.error(f"网页抓取失败: {e}")
        return f"抓取网页失败：{e}"

# ---------- 数据处理 ----------
def process_data_file(path, operation, params=None):
    if pd is None:
        return "数据处理需要安装 pandas 和 openpyxl"
    if not os.path.exists(path):
        return f"文件不存在: {path}"
    try:
        if path.endswith('.csv'):
            df = pd.read_csv(path)
        elif path.endswith(('.xls', '.xlsx')):
            df = pd.read_excel(path)
        else:
            return "仅支持 CSV/Excel"
        if operation == "describe":
            return df.describe().to_string()
        elif operation == "head":
            n = int(params.get("n", 5)) if params else 5
            return df.head(n).to_string()
        elif operation == "columns":
            return str(list(df.columns))
        else:
            return f"未知操作: {operation}"
    except Exception as e:
        return f"数据处理错误：{e}"

def image_caption(path):
    if not os.path.exists(path):
        return f"图片不存在: {path}"
    global reader_easyocr
    if reader_easyocr is None:
        if easyocr:
            reader_easyocr = easyocr.Reader(['ch_sim', 'en'])
        else:
            return "OCR 需要安装 easyocr"
    try:
        result = reader_easyocr.readtext(path)
        text = " ".join([item[1] for item in result])
        return f"图片文字识别：{text if text else '(无文字)'}"
    except Exception as e:
        return f"OCR 错误：{e}"

def text_to_speech(text, filename="tts_output.mp3"):
    global tts_engine
    if tts_engine is None:
        if pyttsx3:
            tts_engine = pyttsx3.init()
        else:
            return "TTS 需要安装 pyttsx3"
    try:
        tts_engine.save_to_file(text, filename)
        tts_engine.runAndWait()
        return f"语音已保存至 {filename}"
    except Exception as e:
        return f"TTS 错误：{e}"

def execute_skill(skill_name, params):
    skill_file = os.path.join(SKILLS_DIR, f"{skill_name}.py")
    if not os.path.exists(skill_file):
        return f"技能 {skill_name} 不存在"
    try:
        spec = importlib.util.spec_from_file_location(skill_name, skill_file)
        module = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(module)
        if hasattr(module, "run"):
            result = module.run(params)
            return str(result)
        else:
            return f"技能 {skill_name} 缺少 run(params) 函数"
    except Exception as e:
        return f"技能执行错误：{e}"

def execute_tool(tool_name, params):
    if tool_name == "run_command":
        return run_command(params.get("command", ""))
    elif tool_name == "search_web":
        return search_web(params.get("query", ""), params.get("max_results", 5))
    elif tool_name == "search_news":
        return search_news(params.get("query", ""), params.get("max_results", 5))
    elif tool_name == "search_images":
        return search_images(params.get("query", ""), params.get("max_results", 5))
    elif tool_name == "fetch_webpage":
        return fetch_webpage(params.get("url", ""))
    elif tool_name == "process_data":
        return process_data_file(params.get("path"), params.get("operation"), params.get("params"))
    elif tool_name == "image_caption":
        return image_caption(params.get("path", ""))
    elif tool_name == "text_to_speech":
        return text_to_speech(params.get("text", ""), params.get("filename", "tts_output.mp3"))
    elif tool_name == "run_skill":
        return execute_skill(params.get("skill"), params.get("params", {}))
    else:
        return f"未知工具: {tool_name}"

# ---------- 模型加载与生成 ----------
def load_model(path, device="cpu"):
    global model, model_type, model_info
    if not os.path.exists(path):
        raise FileNotFoundError(f"模型路径不存在: {path}")
    if path.lower().endswith(".gguf"):
        try:
            from llama_cpp import Llama
            chat_format = None
            if "chatml" in path.lower():
                chat_format = "chatml"
            elif "llama-3" in path.lower() or "llama3" in path.lower():
                chat_format = "llama-3"
            elif "mistral" in path.lower() or "mixtral" in path.lower():
                chat_format = "mistral-instruct"
            elif "qwen" in path.lower():
                chat_format = "chatml"
            model = Llama(
                model_path=path,
                n_ctx=4096,
                n_threads=os.cpu_count(),
                verbose=False,
                chat_format=chat_format
            )
            model_type = "gguf"
            model_info = {
                "chat_format": chat_format,
                "stop": model.detokenize([model.token_eos()]).decode() if hasattr(model, 'token_eos') else ["</s>"]
            }
            logger.info(f"GGUF 模型加载成功，chat_format={chat_format}")
            return True
        except ImportError:
            raise ImportError("需要安装 llama-cpp-python")
    else:
        raise ValueError("目前仅支持 .gguf 格式的模型文件")

def generate_sync(messages, max_tokens, temperature, top_p, top_k, repeat_penalty):
    if model_type != "gguf" or model is None:
        return "模型未正确加载"
    try:
        response = model.create_chat_completion(
            messages=messages,
            max_tokens=max_tokens,
            temperature=temperature,
            top_p=top_p,
            top_k=top_k,
            repeat_penalty=repeat_penalty,
            stop=model_info.get("stop", ["</s>"])
        )
        return response["choices"][0]["message"]["content"]
    except Exception as e:
        logger.error(f"生成失败: {e}")
        return f"模型生成错误: {str(e)}"

