@app.route('/api/chat', methods=['POST'])
def chat():
    global model, conversation_history, current_config, _pending_warning_command
    if model is None:
        return jsonify({'ok': False, 'error': '请先加载模型'})

    data = request.json
    user_input = data.get('message', '').strip()
    if not user_input:
        return jsonify({'ok': False, 'error': '输入为空'})

    # 处理等待中的危险命令确认
    if _pending_warning_command:
        cmd_info = _pending_warning_command
        cmd = cmd_info["command"]
        if "同意执行" in user_input:
            _pending_warning_command = None
            if check_command_danger_level(cmd) == 2:
                exec_result = "严重危险命令，二次拦截。"
            else:
                exec_result = _execute_command_safe(cmd)
            return jsonify({'ok': True, 'reply': f"✅ 您已同意执行（后果自负）：\n```\n{cmd}\n```\n结果：\n{exec_result}"})
        elif "拒绝" in user_input:
            _pending_warning_command = None
            return jsonify({'ok': True, 'reply': f"❌ 已取消执行命令：\n```\n{cmd}\n```"})

    # 构建系统提示词
    memory_lines = load_memory()
    memory_text = "\n".join(f"- {line}" for line in memory_lines[-10:]) if memory_lines else ""
    user_pref = get_long_memory("user_preferences") or ""
    system_prompt = f"{memory_text}\n{user_pref}\n" + """你是星璇，智能助手。你可以使用以下工具完成任务，输出 JSON 格式：
{"tool": "工具名", "params": {...}}
可选工具：
- run_command: 执行命令 (params: command)
- browser_navigate: 打开网页 (params: url) 返回页面ID
- browser_click: 点击元素 (params: selector, page_id)
- browser_fill: 填充输入框 (params: selector, text, page_id)
- browser_screenshot: 截图 (params: page_id, path)
- capture_camera: 拍照 (params: filename)
- image_caption: 图片OCR (params: path, lang)
- text_to_speech: 文字转语音 (params: text, filename)
- search_web: 搜索 (params: query)
- scrape_web: 抓取网页 (params: url, selector)
- process_data: 处理CSV/Excel (params: path, operation, params)
- add_job/remove_job/get_jobs: 定时任务管理
- run_skill: 执行技能 (params: skill, params)
如果需要调用工具，仅输出该 JSON 对象，不要附加其他文字。如果无需工具，正常自然回答。"""

    messages = [{"role": "system", "content": system_prompt}]
    messages += conversation_history[-10:]
    messages.append({"role": "user", "content": user_input})

    # ReAct 循环，最多5次工具调用
    final_reply = ""
    tool_call = None
    used_tool = False
    for _ in range(5):
        raw_output = generate_sync(messages,
                                   current_config['max_tokens'],
                                   current_config['temperature'],
                                   current_config['top_p'],
                                   current_config['top_k'],
                                   current_config['repeat_penalty'])
        json_match = re.search(r'\{.*\}', raw_output, re.DOTALL)
        if json_match:
            try:
                obj = json.loads(json_match.group())
                if "tool" in obj and "params" in obj:
                    tool_name = obj["tool"]
                    params = obj.get("params", {})
                    assistant_msg = {"role": "assistant", "content": json.dumps(obj, ensure_ascii=False)}
                    messages.append(assistant_msg)
                    conversation_history.append(assistant_msg)

                    tool_result = execute_tool(tool_name, params)
                    tool_msg = {"role": "user", "content": f"工具返回结果: {tool_result}"}
                    messages.append(tool_msg)
                    conversation_history.append(tool_msg)

                    tool_call = obj
                    used_tool = True
                    continue
            except json.JSONDecodeError:
                pass
        final_reply = raw_output
        break

    if not final_reply:
        final_reply = "思考中…（达到工具调用上限）"

    conversation_history.append({"role": "assistant", "content": final_reply})
    if len(conversation_history) > 20:
        conversation_history = conversation_history[-20:]

    return jsonify({'ok': True, 'reply': final_reply, 'tool_call': tool_call, 'used_tool': used_tool})

