    return jsonify({'ok': False})
@app.route('/api/memory/clear', methods=['POST'])
def clear_memory():
    clear_all_memory()
    clear_all_long_memory()
    return jsonify({'ok': True})
@app.route('/api/memory/<int:idx>', methods=['DELETE'])
def del_memory(idx):
    delete_memory_item(idx)
    return jsonify({'ok': True})
@app.route('/api/memory/<int:idx>', methods=['PUT'])
def edit_memory(idx):
    new_text = request.json.get('text', '').strip()
    if new_text:
        update_memory_item(idx, new_text)
        return jsonify({'ok': True})
    return jsonify({'ok': False})
@app.route('/api/long_memory', methods=['GET'])
def get_long_memory_route():
    key = request.args.get('key')
    value = get_long_memory(key) if key else None
    return jsonify({'ok': True, 'value': value})
@app.route('/api/long_memory', methods=['POST'])
def set_long_memory_route():
    key = request.json.get('key')
    value = request.json.get('value')
    if key:
        set_long_memory(key, value)
        return jsonify({'ok': True})
    return jsonify({'ok': False})
@app.route('/api/save_config', methods=['POST'])
def save_config():
    global current_config
    data = request.json
    for k in ['temperature','top_p','top_k','repeat_penalty','max_tokens','enable_search']:
        if k in data:
            current_config[k] = data[k]
    return jsonify({'ok': True})

