# ========== 短期记忆 ==========
def load_memory():
    if not os.path.exists(MEMORY_FILE): return []
    with open(MEMORY_FILE, 'r', encoding='utf-8') as f:
        return [line.strip() for line in f if line.strip()]
def save_memory(lines):
    with open(MEMORY_FILE, 'w', encoding='utf-8') as f:
        f.write("\n".join(lines))
def add_memory_item(item):
    lines = load_memory()
    lines.append(item)
    save_memory(lines)
def delete_memory_item(idx):
    lines = load_memory()
    if 0 <= idx < len(lines):
        del lines[idx]
        save_memory(lines)
def update_memory_item(idx, new_text):
    lines = load_memory()
    if 0 <= idx < len(lines):
        lines[idx] = new_text
        save_memory(lines)
def clear_all_memory():
    save_memory([])

# ========== 工具实现 ==========
def _execute_command_safe(cmd):
    try:
        res = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=20)
        out = res.stdout + res.stderr
        return out[:2000] if out.strip() else "✅ 命令已执行成功"
    except subprocess.TimeoutExpired:
        return "⏰ 命令执行超时（20秒）"
    except Exception as e:
        return f"❌ 执行失败: {str(e)}"

def run_command(cmd):
    level = check_command_danger_level(cmd)
    if level == 2:
        logger.warning(f"拦截严重危险命令: {cmd}")
        return "⚠️ **严重危险命令已自动拦截**\n\n该命令可能破坏系统，星璇已拒绝执行。"
    elif level == 1:
        global _pending_warning_command
        _pending_warning_command = {"command": cmd, "pending_since": time.time()}
        return (
            "⚠️ **此操作可能影响系统稳定性或数据安全**\n\n"
            f"命令：`{cmd}`\n\n"
            "**免责声明**：继续执行此操作可能造成系统异常、数据丢失等后果。\n"
            "您明确知晓并自愿承担所有风险。\n\n"
            "请选择：\n- 回复「**同意执行**」继续（后果自负）\n- 回复「**拒绝**」取消操作"
        )
    return _execute_command_safe(cmd)

# --- 浏览器自动化（Playwright）---
def _get_browser():
    """获取或创建浏览器上下文（可复用）"""
    global browser_context
    try:
        from playwright.sync_api import sync_playwright
    except ImportError:
        return None
    if browser_context is None:
        playwright = sync_playwright().start()
        browser = playwright.chromium.launch(headless=True)
        browser_context = browser.new_context()
    return browser_context

def browser_navigate(url):
    try:
        ctx = _get_browser()
        if not ctx:
            return "请安装 playwright：pip install playwright && playwright install chromium"
        page = ctx.new_page()
        page.goto(url, timeout=15000)
        title = page.title()
        # 保存页面引用，方便后续操作
        page.set_extra_http_headers({"User-Agent": "Mozilla/5.0"})
        # 返回标题，后续可通过page_id获取
        page_id = str(uuid.uuid4())
        # 存储到全局字典中
        if not hasattr(browser_navigate, 'pages'):
            browser_navigate.pages = {}
        browser_navigate.pages[page_id] = page
        return f"已打开网页：{title}\n页面ID：{page_id}（可用于后续点击、填充）"
    except Exception as e:
        return f"浏览器错误：{e}"

def browser_click(selector, page_id=None):
    try:
        if page_id and hasattr(browser_navigate, 'pages'):
            page = browser_navigate.pages.get(page_id)
            if not page:
                return "页面不存在或已关闭"
            page.click(selector)
            return f"已点击元素：{selector}"
        else:
            return "请提供有效的页面ID（来自 browser_navigate 返回的ID）"
    except Exception as e:
        return f"点击失败: {e}"

def browser_fill(selector, text, page_id=None):
    try:
        if page_id and hasattr(browser_navigate, 'pages'):
            page = browser_navigate.pages.get(page_id)
            if not page:
                return "页面不存在或已关闭"
            page.fill(selector, text)
            return f"已填充 {selector} 为 {text}"
        else:
            return "请提供有效的页面ID"
    except Exception as e:
        return f"填充失败: {e}"

def browser_screenshot(page_id=None, path=None):
    try:
        if page_id and hasattr(browser_navigate, 'pages'):
