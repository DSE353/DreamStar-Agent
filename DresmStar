@app.route('/api/load', methods=['POST'])
def api_load():
    global model, current_config
    data = request.json
    path = data.get('path', '').strip()
    if not path:
        return jsonify({'ok': False, 'error': '路径不能为空'})
    try:
        load_model(path)
        for k in ['temperature','top_p','top_k','repeat_penalty','max_tokens','enable_search']:
            if k in data:
                current_config[k] = data[k]
        return jsonify({'ok': True, 'message': '模型加载成功'})
    except Exception as e:
        return jsonify({'ok': False, 'error': str(e)})

