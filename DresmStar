# --- 摄像头拍照 ---
def capture_camera(filename=None):
    try:
        cap = cv2.VideoCapture(0)
        if not cap.isOpened():
            return "无法打开摄像头"
        ret, frame = cap.read()
        cap.release()
        if not ret:
            return "拍照失败"
        if not filename:
            filename = os.path.join(TEMP_DIR, f"capture_{uuid.uuid4().hex}.jpg")
        cv2.imwrite(filename, frame)
        # 同时返回 base64 方便预览
        _, buffer = cv2.imencode('.jpg', frame)
        b64_str = base64.b64encode(buffer).decode('utf-8')
        return f"拍照成功，保存至 {filename}\nBase64 预览：data:image/jpeg;base64,{b64_str[:50]}..."
    except Exception as e:
        return f"摄像头错误：{e}"

# --- OCR 图片文字识别 ---
def image_caption(path, lang='ch_sim+en'):
    if not os.path.exists(path):
        return f"图片不存在: {path}"
    try:
        reader = safe_import("easyocr")
        if not reader:
            return "请安装 easyocr"
        # 创建 Reader（只初始化一次）
        if not hasattr(image_caption, 'reader_cache'):
            image_caption.reader_cache = {}
        if lang not in image_caption.reader_cache:
            image_caption.reader_cache[lang] = reader.Reader(lang.split('+'))
        ocr_reader = image_caption.reader_cache[lang]
        result = ocr_reader.readtext(path)
        text = " ".join([item[1] for item in result])
        return f"图片文字识别结果：{text if text else '(无文字)'}"
    except Exception as e:
        return f"OCR 错误：{e}"

# --- TTS 语音合成 ---
def text_to_speech(text, filename=None):
    try:
        pyttsx3 = safe_import("pyttsx3")
        if not pyttsx3:
            return "请安装 pyttsx3"
        if not filename:
            filename = os.path.join(TEMP_DIR, f"tts_{uuid.uuid4().hex}.mp3")
        engine = pyttsx3.init()
        engine.save_to_file(text, filename)
        engine.runAndWait()
        return f"语音已保存至 {filename}"
    except Exception as e:
        return f"TTS 错误：{e}"

# --- 网络搜索 ---
def search_web(query):
    if not current_config.get('enable_search', True):
        return "联网搜索已禁用"
    try:
        ddg = safe_import("duckduckgo_search")
        if not ddg:
            return "请安装 duckduckgo-search"
        from duckduckgo_search import DDGS
        with DDGS() as ddgs:
            results = list(ddgs.text(query, max_results=5))
        if not results:
            return f"未找到“{query}”的相关结果"
        formatted = "\n".join(f"- {r['title']}: {r['href']}" for r in results)
        return f"搜索“{query}”结果：\n{formatted}"
    except Exception as e:
        return f"搜索出错：{e}"

# --- 网页内容抓取 ---
def scrape_web(url, selector=None):
    try:
        headers = {'User-Agent': 'Mozilla/5.0'}
        resp = http_requests.get(url, headers=headers, timeout=10)
        resp.encoding = resp.apparent_encoding
        soup = BeautifulSoup(resp.text, 'html.parser')
        if selector:
            elements = soup.select(selector)
            if not elements:
                return f"未找到选择器 {selector} 匹配的元素"
            texts = [el.get_text(strip=True) for el in elements[:10]]
            return "提取内容：\n" + "\n---\n".join(texts)
        else:
            # 返回页面标题和所有文本
            title = soup.title.string if soup.title else "无标题"
            text = soup.get_text(" ", strip=True)[:2000]
            return f"页面标题：{title}\n内容摘要：\n{text}"
    except Exception as e:
        return f"抓取失败：{e}"

# --- 数据处理 ---
def process_data_file(path, operation, params=None):
    pd = safe_import("pandas")
    if not pd:
        return "请安装 pandas/openpyxl"
    if not os.path.exists(path):
        return f"文件不存在: {path}"
    try:
        if path.endswith('.csv'):
            df = pd.read_csv(path)
        elif path.endswith(('.xls', '.xlsx')):
            df = pd.read_excel(path)
        else:
            return "仅支持 CSV/Excel"
        if operation == "describe":
            return df.describe().to_string()
        elif operation == "head":
            n = int(params.get("n", 5)) if params else 5
            return df.head(n).to_string()
        elif operation == "columns":
            return str(list(df.columns))
        elif operation == "tail":
            n = int(params.get("n", 5)) if params else 5
            return df.tail(n).to_string()
        elif operation == "info":
            buf = io.StringIO()
            df.info(buf=buf)
            return buf.getvalue()
        else:
            return f"未知操作: {operation}"
    except Exception as e:
        return f"数据处理错误：{e}"

# --- 定时任务 ---
def add_job(job_id, func_name, trigger_type, trigger_args, **kwargs):
    try:
        if trigger_type == 'cron':
            trigger = CronTrigger(**trigger_args)
        elif trigger_type == 'interval':
            trigger = IntervalTrigger(**trigger_args)
        else:
            return "不支持的触发器类型"
        # 从全局函数映射中获取函数
        func = globals().get(func_name)
        if not func:
            return f"函数 {func_name} 不存在"
        scheduler.add_job(func, trigger, id=job_id, **kwargs)
        return f"定时任务 {job_id} 已添加"
    except Exception as e:
        return f"添加任务失败：{e}"

def remove_job(job_id):
    try:
        scheduler.remove_job(job_id)
        return f"任务 {job_id} 已移除"
    except Exception as e:
        return f"移除失败：{e}"

def get_jobs():
    jobs = scheduler.get_jobs()
    res = []
    for job in jobs:
        res.append(f"ID: {job.id}, 下次运行: {job.next_run_time}")
    return "\n".join(res) if res else "无定时任务"

