# ========== 危险命令分级黑名单 ==========
CRITICAL_PATTERNS = [
    r"rm\s+(-[rf]+)+\s*/", r"rm\s+(-[rf]+)+\s*/\*", r"rm\s+(-[rf]+)+\s*~",
    r"dd\s+if=/dev/(zero|urandom|random)\s+of=/dev/sd[a-z]",
    r"mkfs\.\w+\s+/dev/", r"format\s+[c-z]:", r"del\s+/(f|q)/s\s+[c-z]:\\\\",
    r"rd\s+/s/q\s+[c-z]:\\\\", r"chmod\s+-R\s+777\s+/", r"chown\s+-R\s+nobody:\s+/",
    r"userdel\s+-r\s+root", r"iptables\s+-F", r"systemctl\s+mask",
    r"reg\s+delete\s+HKLM\s+/f", r":\(\)\{\s*:\|:&\s*\};:", r"%0\|%0",
    r"(wget|curl)\s+.*\s*\|\s*(sh|bash)", r"sudo\s+.*(rm|dd|mkfs)",
    r"su\s+-c\s+[\"'].*(rm|dd|mkfs).*[\"']", r"/bin/(rm|dd|mkfs)",
    r"['\"]rm['\"]\s+-rf\s+/", r"r\\m\s+-rf\s+/", r"Sudo\s+rm",
]
WARNING_PATTERNS = [
    r"rm\s+-rf\s+~/(Documents|Downloads|Desktop|Pictures)",
    r"rm\s+-rf\s+~/\.\w+", r"systemctl\s+(stop|disable|kill)\s+\w+",
    r"kill\s+-9\s+[1-9]\d*", r">\s*/var/log/\w+\.log",
]

CRITICAL_REGEX = [re.compile(p, re.IGNORECASE) for p in CRITICAL_PATTERNS]
WARNING_REGEX   = [re.compile(p, re.IGNORECASE) for p in WARNING_PATTERNS]

def check_command_danger_level(cmd: str) -> int:
    try:
        decoded = unquote(cmd)
    except:
        decoded = cmd
    cmd_clean = decoded.strip()
    for r in CRITICAL_REGEX:
        if r.search(cmd_clean):
            return 2
    for r in WARNING_REGEX:
        if r.search(cmd_clean):
            return 1
    return 0

